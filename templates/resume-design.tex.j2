%----------------------------------------------------------------------------------------
%   {{ profile.name | latex }} — {{ profile.title | latex }} resume (design version)
%   Generated from resume-data.yml with Jinja2
%----------------------------------------------------------------------------------------
\documentclass[10pt,a4paper]{article}

%----------------------------------------------------------------------------------------
%   PDF TEXT EXTRACTION / ATS SAFETY
%----------------------------------------------------------------------------------------
\input{glyphtounicode}
\pdfgentounicode=1

%----------------------------------------------------------------------------------------
%   PACKAGES
%----------------------------------------------------------------------------------------
\usepackage[T1]{fontenc}
\usepackage[utf8]{inputenc}
\usepackage[default]{raleway}
\renewcommand*\familydefault{\sfdefault}

\usepackage[a4paper,top=1cm,bottom=1cm,left=1.2cm,right=1.2cm,footskip=0.8cm]{geometry}
\usepackage[hidelinks]{hyperref}
\usepackage[final]{microtype}
\usepackage{xcolor}
\usepackage{pagecolor}
\usepackage{enumitem}
\usepackage[most]{tcolorbox}
\usepackage{fontawesome}
\usepackage{fancyhdr}
\usepackage{ragged2e}
\usepackage{ifthen}

%----------------------------------------------------------------------------------------
%   COLORS
%----------------------------------------------------------------------------------------
\definecolor{cvbg}{HTML}{F9F9EC}
\definecolor{cvtext}{HTML}{141414}
\definecolor{cvmute}{HTML}{6B6B6B}
\definecolor{cvsoft}{HTML}{B5ADA5}
\definecolor{cvline}{HTML}{E8E4DF}
\definecolor{cvaccent}{HTML}{26B9A4}
\definecolor{cvpink}{HTML}{FC0096}

\pagecolor{cvbg}
\color{cvtext}
\setlength{\parindent}{0pt}
\setlength{\parskip}{0pt}

%----------------------------------------------------------------------------------------
%   PAGE STYLE
%----------------------------------------------------------------------------------------
\pagestyle{fancy}
\fancyhf{}
\renewcommand{\headrulewidth}{0pt}
\renewcommand{\footrulewidth}{0pt}
\renewcommand{\thepage}{}
\fancyfoot[C]{\scriptsize\textcolor{cvsoft}{Last update: {{ last_updated | default("", true) | latex }}}}

\fancypagestyle{plain}{ %
  \fancyhf{}
  \renewcommand{\headrulewidth}{0pt}
  \renewcommand{\footrulewidth}{0pt}
  \fancyfoot[C]{\scriptsize\textcolor{cvsoft}{Last update: {{ last_updated | default("", true) | latex }}}}
}

%----------------------------------------------------------------------------------------
%   BASICS
%----------------------------------------------------------------------------------------
\newcommand{\pink}[1]{\textcolor{cvpink}{\textbf{#1}}}
\newcommand{\muted}[1]{\textcolor{cvmute}{#1}}
\newcommand{\sectiongap}{\vspace{12pt}}

\newcommand{\cvsect}[1]{ %
  {\small\textcolor{cvaccent}{\MakeUppercase{\textbf{#1}}}}\\[-0.2em]
  \textcolor{cvaccent}{\rule{\linewidth}{1pt}}\\[0.4em]
}

\newcommand{\icon}[2]{ %
  \colorbox{cvaccent}{\makebox(#2,#2){\textcolor{cvbg}{\large\csname fa#1\endcsname}}}%
}

\newcommand{\icontext}[3]{ %
  \icon{#1}{#2}\hspace{0.25cm}\textcolor{cvtext}{#3}%
}

%----------------------------------------------------------------------------------------
%   LISTS
%----------------------------------------------------------------------------------------
\newlist{cvbullets}{itemize}{1}
\setlist[cvbullets]{ %
  label=\raisebox{0.2ex}{\textcolor{cvaccent}{\rule{0.65ex}{0.65ex}}},
  leftmargin=1.1em,
  labelsep=0.55em,
  itemsep=1.5pt,
  topsep=2pt,
  parsep=0pt,
  partopsep=0pt
}

%----------------------------------------------------------------------------------------
%   CARDS
%----------------------------------------------------------------------------------------
\tcbset{
  cvcard/.style={
    enhanced,
    colback=cvbg,
    colframe=cvline,
    boxrule=0.55pt,
    arc=2mm,
    left=3mm,
    right=3mm,
    top=2.2mm,
    bottom=2.2mm,
    boxsep=0pt,
    before skip=0pt,
    after skip=0pt
  }
}

\newcommand{\skillcard}[2]{ %
  \begin{tcolorbox}[cvcard]
    {\small\pink{\MakeUppercase{#1}}}%
    \par\vspace{1.8mm}
    {\small #2}
  \end{tcolorbox}%
}

\newcommand{\entrycard}[4]{ %
  \begin{tcolorbox}[cvcard,width=\linewidth]
    \begin{minipage}[t]{0.19\linewidth}
      {\footnotesize\textcolor{cvmute}{#1}}
    \end{minipage}%
    \hfill
    \begin{minipage}[t]{0.77\linewidth}
      {\textcolor{cvaccent}{\textbf{#2}}}%
      \hfill
      {\small\pink{\textbf{#3}}}
      \par\vspace{1.7mm}
      #4
    \end{minipage}
  \end{tcolorbox}
  \vspace{2.2mm}
}

\newcommand{\smallcard}[2]{ %
  \begin{tcolorbox}[cvcard]
    {\small\pink{\MakeUppercase{#1}}}
    \par\vspace{1.8mm}
    {\small #2}
  \end{tcolorbox}%
}

%----------------------------------------------------------------------------------------
%   TECH PILLS
%----------------------------------------------------------------------------------------
\newcommand{\tech}[1]{ %
  \tcbox[
    on line,
    colback=cvbg,
    colframe=cvline,
    boxrule=0.4pt,
    arc=1.5mm,
    left=1mm,
    right=1mm,
    top=0.45mm,
    bottom=0.45mm,
    boxsep=0pt
  ]{\scriptsize\texttt{\textcolor{cvmute}{#1}}}%
}

\newcommand{\techline}[1]{ %
  \par\vspace{2mm}%
  {\raggedright #1\par}%
}

%----------------------------------------------------------------------------------------
%   DOCUMENT
%----------------------------------------------------------------------------------------
\begin{document}
\small

%----------------------------------------------------------------------------------------
%   HEADER
%----------------------------------------------------------------------------------------
\begin{minipage}[t]{0.7\textwidth}\hrule height 0pt width 0pt%
    {\Huge\textbf{Hello, I'm \pink{ {{ profile.name | latex }} }.}}\\[-0.1em]
    {\Large {{ profile.title | latex }}}\\[0.45em]
    \textcolor{cvmute}{ {{ profile.summary | latex }} }
  \end{minipage}%
  \hfill
  \begin{minipage}[t]{0.26\textwidth}\hrule height 0pt width 0pt%
    \small
    \icontext{MapMarker}{12}{ {{ profile.location | latex }} }\\
    \icontext{At}{12}{\href{mailto:{{ profile.email | url }}}{ {{ profile.email | latex }} }}\\
    \icontext{Globe}{12}{\href{https://{{ profile.website | url }}}{ {{ profile.website | latex }} }}\\
    \icontext{Linkedin}{12}{\href{https://{{ profile.linkedin | url }}}{ {{ profile.linkedin | latex }} }}\\
    \icontext{Github}{12}{\href{https://{{ profile.github | url }}}{ {{ profile.github | latex }} }}
  \end{minipage}%
  \par\vspace{6pt}
  \textcolor{cvline}{\rule{\linewidth}{1pt}}
  \vspace{6pt}

%----------------------------------------------------------------------------------------
%   SKILLS
%----------------------------------------------------------------------------------------
\cvsect{Technical Skills}
{% for row in skills | batch(2, none) %}
\begin{minipage}[t]{0.48\textwidth}
{% if row[0] %}
  \skillcard{ {{ row[0].category | latex }} }{ {{ row[0]['items'] | map('latex') | join(' • ') }} }
{% endif %}
\end{minipage}%
\hfill
\begin{minipage}[t]{0.48\textwidth}
{% if row[1] %}
  \skillcard{ {{ row[1].category | latex }} }{ {{ row[1]['items'] | map('latex') | join(' • ') }} }
{% endif %}
\end{minipage}
{% if not loop.last %}\vspace{2.4mm}{% endif %}
{% endfor %}

\sectiongap

%----------------------------------------------------------------------------------------
%   EXPERIENCE
%----------------------------------------------------------------------------------------
\cvsect{Experience}
{% for exp in experiences %}
\entrycard
{ {{ exp.dates | latex }}\\{{ exp.location | latex }} }
{ {{ exp.role | latex }} }
{ {{ exp.company | latex }} }
{
  \muted{ {{ exp.summary | latex }} }

  \begin{cvbullets}
{% for bullet in exp.bullets %}
    \item {{ bullet | latex }}
{% endfor %}
  \end{cvbullets}

{% if exp.technologies %}
  \techline{ {% for tech in exp.technologies %}\tech{ {{ tech | latex }} } {% endfor %}}
{% endif %}
}
{% endfor %}

%----------------------------------------------------------------------------------------
%   PROJECTS
%----------------------------------------------------------------------------------------
{% if projects %}
\sectiongap
\cvsect{Selected Personal Projects}
{% for project in projects %}
\entrycard
{ {{ project.link | display_url | latex }} }
{ {{ project.name | latex }} }
{ Project }
{
{% if project.bullets %}
  \begin{cvbullets}
{% for bullet in project.bullets %}
    \item {{ bullet | latex }}
{% endfor %}
  \end{cvbullets}
{% endif %}

{% if project.link %}
  \textbf{Link:} \href{ {{ project.link | url }} }{ {{ project.link | display_url | latex }} }
{% endif %}
{% if project.technologies %}
  \techline{ {% for tech in project.technologies %}\tech{ {{ tech | latex }} } {% endfor %}}
{% endif %}
}
{% endfor %}
{% endif %}

%----------------------------------------------------------------------------------------
%   EDUCATION
%----------------------------------------------------------------------------------------
{% if education %}
\sectiongap
\cvsect{Education}
{% for edu in education %}
\entrycard
{ {{ edu.dates | latex }} }
{ {{ edu.diploma | latex }} }
{ {{ edu.location | latex }} }
{}
{% endfor %}
{% endif %}

%----------------------------------------------------------------------------------------
%   LANGUAGES
%----------------------------------------------------------------------------------------
{% if languages %}
\sectiongap
\cvsect{Languages}
\begin{tcolorbox}[cvcard,width=\linewidth]
  {\small
{% for lang in languages %}
    \textbf{ {{ lang.language | latex }} }: {{ lang.level | latex }}{% if not loop.last %} \quad \textcolor{cvsoft}{•} \quad{% endif %}
{% endfor %}
  }
\end{tcolorbox}
{% endif %}

\end{document}
